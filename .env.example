# Environment variables for Showrunner
# Core settings
APP_ENV=development
PORT=8000
DATABASE_URL=sqlite:///./showrunner.db

# Luffa integration
LUFFA_API_BASE_URL=https://api.luffa.example.com
LUFFA_API_TOKEN=your_luffa_api_token

# Endless (stubbed) integration
ENDLESS_API_BASE_URL=https://api.endless.example.com
ENDLESS_API_TOKEN=your_endless_api_token

# Civic (stubbed) integration
CIVIC_API_BASE_URL=https://api.civic.example.com
CIVIC_API_TOKEN=your_civic_api_token

# LLM (stubbed) integration
LLM_API_BASE_URL=https://api.llm.example.com

# Payout configuration
ORGANISER_ADDRESS=0xOrganizerAddress
TREASURY_ADDRESS=0xTreasuryAddress
ORGANISER_SHARE=0.9
TREASURY_SHARE=0.1