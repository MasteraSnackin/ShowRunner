# Example environment variables for ShowRunner
# Adjust these values as needed for your local setup
# For example, you might set a secret key or database URL
SECRET_KEY=your-secret-key
DATABASE_URL=sqlite:///./test.db

# Luffa integration
LUFFA_API_BASE_URL=https://api.luffa.example.com
LUFFA_API_TOKEN=your-luffa-token

# Endless integration (stub)
ENDLESS_API_BASE_URL=https://api.endless.example.com
ENDLESS_API_TOKEN=your-endless-token

# Civic integration (stub)
CIVIC_API_BASE_URL=https://api.civic.example.com
CIVIC_API_TOKEN=your-civic-token

# LLM integration (stub)
LLM_API_BASE_URL=https://api.llm.example.com

# Payout configuration
ORGANISER_ADDRESS=0xOrganizerAddress
TREASURY_ADDRESS=0xTreasuryAddress
